{
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com/",
    "TimeoutSeconds": 2
  },
  "StoriesCache": {
    "StoryTtlHours": 24,
    "SnapshotTtlHours": 24,
    "BestIdsTtlHours": 24,
    "WarmupStoryCount": 200,
    "MaxFetchStories": 500,
    "MaxFetchConcurrency": 20,
    "RefreshIntervalMinutes": 720
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
